{
  // Equation-handle macros for the built-in Markdown math preview (KaTeX).
  // The live site (MathJax) gets the same handles from _includes/custom-head.html.
  // KaTeX has no \label/\eqref linking, so \eqref renders as plain "(id)" text here;
  // on the site it is a clickable cross-reference. See CONVENTIONS.md §1.
  "markdown.math.macros": {
    "\\ltag": "\\tag{#1}",
    "\\eqref": "(\\text{#1})",
    // \veq{h}\tier — numbered tag carrying handle + verification badge, e.g. (edot ✓).
    //   2nd arg is a single-token tier macro (no braces needed). KaTeX has no \label, so
    //   the handle is just the visible (tag); the badge is $...$-wrapped so the math glyph
    //   renders inside the text-mode tag. (\ltag stays for not-yet-migrated handles.)
    // \veqs{h}\tier (id:a138) — unnumbered sub-step / inline variant: badge shown in
    //   parens, handle hidden entirely (id:9c41 owner render directive 2026-06-18).
    //   A \veq* star variant is INFEASIBLE (MathJax \@ifstar breaks the 2nd \veq in a page —
    //   see custom-head.html), so the unnumbered form is the distinct macro \veqs (both DIRECT).
    //   KaTeX has no \label, and a 2-arg macro must reference #1, so \veqs stores the handle
    //   via \def (never rendered — no visible glyphs) to keep it out of the editor preview,
    //   matching the published MathJax site's \label-hidden handle.
    // TODO id:feb8 — \tier* open-debt notation (deferred).
    "\\veq":      "\\tag{#1\\,$#2$}",
    "\\veqs":     "\\def\\veqsHandle{#1}(#2)",
    // Verification-tier badge macros (LaTeX symbols — no raw emoji to avoid KaTeX metric warnings).
    "\\sorry":    "\\mathbf{?}",
    "\\sympy":    "\\circ",
    "\\numeric":  "\\triangle",
    "\\lean":     "\\checkmark",
    "\\sympylean": "\\checkmark\\!\\checkmark",
    // Open-debt badges naming the DESIRED-but-unverified tier (id:feb8 resolved): tier glyph +
    // superscript ? . Swap \sympyc → \sympy once the instrument greens + the sidecar attests.
    "\\sympyc":    "\\circ^{?}",
    "\\numericc":  "\\triangle^{?}",
    "\\leanc":     "\\checkmark^{?}",
    "\\sympyleanc": "{\\checkmark\\!\\checkmark}^{?}",
    // Annotation-KIND macros (pilot — id:8ddc/.mw id:358f open-enum kinds): \definition (:=),
    // \assumption (premise). Full kind taxonomy is a later /meeting.
    "\\definition": "\\mathrm{def}",
    "\\assumption": "\\mathrm{ass}"
  }
}
